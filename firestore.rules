rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isMe(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    match /users/{uid} {
      allow read: if signedIn();
      allow create: if isMe(uid);
      allow update: if signedIn();
      allow delete: if false;
    }

    match /usernames/{usernameLower} {
      allow read: if signedIn();
      allow create, update: if signedIn() && request.resource.data.uid == request.auth.uid;
      allow delete: if signedIn() && resource.data.uid == request.auth.uid;
    }

    match /friendRequests/{requestId} {
      allow read: if signedIn() && (resource.data.fromUid == request.auth.uid || resource.data.toUid == request.auth.uid);
      allow create: if signedIn() && request.resource.data.fromUid == request.auth.uid;
      allow update: if signedIn() && (resource.data.fromUid == request.auth.uid || resource.data.toUid == request.auth.uid);
      allow delete: if false;
    }

    match /friends/{uid}/list/{friendUid} {
      allow read: if isMe(uid);
      allow write: if signedIn() && (request.auth.uid == uid || request.auth.uid == friendUid);
    }

    match /inventories/{uid} {
      allow read: if isMe(uid);
      allow write: if signedIn();
    }

    match /activeBoosts/{uid} {
      allow read, write: if isMe(uid);
    }

    match /trades/{tradeId} {
      allow read: if signedIn() && request.auth.uid in resource.data.participants;
      allow create: if signedIn() && request.resource.data.fromUid == request.auth.uid;
      allow update: if signedIn() && request.auth.uid in resource.data.participants;
      allow delete: if false;
    }

    match /transfers/{transferId} {
      allow read: if signedIn() && request.auth.uid in resource.data.participants;
      allow create: if signedIn() && request.resource.data.fromUid == request.auth.uid;
      allow update, delete: if false;
    }
  }
}
